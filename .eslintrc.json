{
  "extends": [
    "airbnb",
    "prettier",
    "plugin:jest/recommended",
    "plugin:testing-library/react",
    "plugin:jest-dom/recommended"
  ],
  "parser": "@babel/eslint-parser",
  "plugins": ["prettier", "jest", "testing-library", "jest-dom"],
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module",
    "requireConfigFile": false,
    "babelOptions": {
      "presets": ["@babel/preset-env", "@babel/preset-react"]
    }
  },
  "env": {
    "es6": true,
    "browser": true,
    "node": true,
    "jest": true
  },
  "rules": {
    "array-bracket-spacing": [2, "never"],
    "eol-last": ["error", "always"],
    "semi": [2, "always"],
    "jsx-a11y/label-has-for": 0,
    "react/prefer-stateless-function": [0],
    "react/jsx-filename-extension": [
      1,
      {
        "extensions": [".js", ".jsx"]
      }
    ],
    "react/jsx-props-no-spreading": 0,
    "react/forbid-prop-types": 0,
    "react/sort-comp": [0],
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": [
          "**/*.test.js",
          "**/*test-utils.js",
          "**/jest.config.js",
          "browser-test/utils.js"
        ]
      }
    ],
    "camelcase": [
      "error",
      {
        "allow": [
          "accounting_swap_octets",
          "additional_fields",
          "additional_info_text",
          "additional_text",
          "after_html",
          "active_session",
          "alternate_text",
          "assets_confirm",
          "auth_token",
          "auto_select_first_plan",
          "auto_switch_phone_input",
          "birth_date",
          "billing_info",
          "calling_station_id",
          "confirm_password",
          "contact_page",
          "contact_text",
          "create_mobile_phone_token",
          "css_path",
          "current_password",
          "default_language",
          "device_address",
          "divider_text",
          "enable_search",
          "exclude_countries",
          "first_name",
          "forget_password",
          "forgot_password",
          "has_automatic_renewal",
          "help_html",
          "homepage_link",
          "input_fields",
          "input_octets",
          "intro_html",
          "is_active",
          "is_free",
          "is_open",
          "is_verified",
          "last_name",
          "login_action_url",
          "login_form",
          "login_page_link",
          "logout_action_url",
          "logout_by_session",
          "logout_by_session_ID",
          "macaddr_param_name",
          "methods_excluded",
          "methods_only",
          "mobile_phone_number_change",
          "mobile_phone_token_status",
          "mobile_phone_verification",
          "new_password",
          "new_password1",
          "new_password2",
          "non_field_errors",
          "only_countries",
          "openwisp_radius_url",
          "optional_fields",
          "password_change",
          "password_confirm",
          "password_expired",
          "password_reset",
          "password_reset_confirm",
          "payment_iframe",
          "payment_requires_internet",
          "payment_status",
          "payment_url",
          "phone_number",
          "plan_description",
          "plan_pricing",
          "preferred_countries",
          "pre_html",
          "privacy_policy",
          "radius_realms",
          "radius_usage_enabled",
          "radius_user_token",
          "remember_me",
          "response_code",
          "requires_invoice",
          "requires_payment",
          "second_logo",
          "secret_key",
          "sesame_token",
          "session_id",
          "session_info",
          "session_time",
          "saml_logout_url",
          "social_links",
          "social_login",
          "start_time",
          "sticky_html",
          "stop_time",
          "sub_heading",
          "tax_number",
          "terms_and_conditions",
          "time_option",
          "user_info",
          "user_plan_radius_usage",
          "user_radius_sessions",
          "user_radius_usage",
          "verify_mobile_phone_token",
          "v7_relativeSplatPath",
          "v7_startTransition",
          "wait_after",
          "output_octets",
          "registration_form",
          "max_attempts"
        ]
      }
    ]
  }
}
